# Helios Protocol backend — example environment variables.
# Copy to backend/.env for local dev. Never commit a real .env.

# Stellar network
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Postgres
DATABASE_URL=postgresql://helios:helios@localhost:5432/helios

# Redis
REDIS_URL=redis://localhost:6379/0

# Optional integrations (leave empty until configured)
REFLECTOR_ORACLE_ADDRESS=
SENTRY_DSN=
